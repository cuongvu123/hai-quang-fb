# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server/cron only — KHÔNG để lộ client

# ---- Tenant mặc định (bản single-xã) ----
DEFAULT_TENANT_ID=11111111-1111-1111-1111-111111111111

# ---- Bảo vệ cron ----
CRON_SECRET=doi-thanh-chuoi-ngau-nhien-dai

# ---- (Tuỳ chọn) mã hoá secret trong bảng settings ----
SETTINGS_ENCRYPTION_KEY=32-bytes-base64

# ---- AI key (đặt vào bảng `settings` qua màn Settings, không cần env) ----
# CLAUDE_API_KEY=...
# OPENAI_API_KEY=...
# GEMINI_API_KEY=...   # khuyến nghị cho bản free, lấy tại https://aistudio.google.com/apikey

# ---- Nạp tin qua Telegram (tuỳ chọn) ----
# Tạo bot với @BotFather để lấy token; SECRET là chuỗi ngẫu nhiên bạn tự đặt.
# Đăng ký webhook 1 lần (xem docs/INGEST_GUIDE.md).
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ---- (Tuỳ chọn) Đăng Group qua GitHub Actions ----
# Để bấm "Đăng ngay" trên Vercel kích GitHub Actions chạy liền (đăng Group Playwright).
# GITHUB_DISPATCH_TOKEN: fine-grained PAT, quyền Contents:read + Metadata cho repo này.
# Bỏ trống vẫn được: workflow publish.yml tự quét & đăng mỗi 15 phút.
GITHUB_DISPATCH_TOKEN=
GITHUB_REPO=cuongvu123/hai-quang-fb
