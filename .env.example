# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server/cron only — KHÔNG để lộ client

# ---- Tenant mặc định (bản single-xã) ----
DEFAULT_TENANT_ID=11111111-1111-1111-1111-111111111111

# ---- Bảo vệ cron ----
CRON_SECRET=doi-thanh-chuoi-ngau-nhien-dai

# ---- (Tuỳ chọn) mã hoá secret trong bảng settings ----
SETTINGS_ENCRYPTION_KEY=32-bytes-base64

# ---- AI key (đặt vào bảng `settings` qua màn Settings, không cần env) ----
